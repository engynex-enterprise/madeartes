# =====================================================================
#  MADEARTES — Variables de entorno
#  Copia este archivo como ".env" y completa con tus valores reales.
#  TODAS deben llevar el prefijo PUBLIC_ para que Astro las inyecte
#  en el HTML del navegador (scripts de Google se ejecutan en el cliente).
# =====================================================================

# ---------- Sitio ----------
# Dominio final del sitio (sin slash al final). Se usa en SEO y sitemap.
PUBLIC_SITE_URL="https://www.madeartes.com"

# Número de WhatsApp en formato internacional, solo dígitos (57 = Colombia).
PUBLIC_WHATSAPP="573154377743"

# Correo y redes sociales (se muestran en la barra superior y el footer).
PUBLIC_EMAIL="contacto@madeartes.com"
PUBLIC_INSTAGRAM="https://instagram.com/madeartes"
PUBLIC_TIKTOK="https://tiktok.com/@madeartes"
PUBLIC_FACEBOOK="https://facebook.com/madeartes"

# =====================================================================
#  GOOGLE — Analítica, etiquetas y publicidad
#  Deja vacía cualquier variable que aún no uses: su script NO se carga.
# =====================================================================

# ---------- Google Tag Manager (recomendado: gestiona TODO desde aquí) ----------
# Formato: GTM-XXXXXXX
PUBLIC_GTM_ID=""

# ---------- Google Analytics 4 (GA4) ----------
# Formato: G-XXXXXXXXXX
# Si ya manejas GA4 dentro de GTM, puedes dejarlo vacío.
PUBLIC_GA4_ID=""

# ---------- Google Ads ----------
# ID de conversión de Google Ads. Formato: AW-XXXXXXXXXX
PUBLIC_GOOGLE_ADS_ID=""
# Etiqueta de conversión (para registrar el envío del formulario como conversión).
# Formato: AbC-D_efGHijkLMnoPQ  (la parte después de la "/")
PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=""

# ---------- Google Search Console ----------
# Código de verificación del sitio (meta tag). Solo el contenido, no la etiqueta.
PUBLIC_GOOGLE_SITE_VERIFICATION=""

# ---------- Google Maps (opcional, para sección de ubicación a futuro) ----------
PUBLIC_GOOGLE_MAPS_API_KEY=""

# =====================================================================
#  ASISTENTE DE IA (chat)
# =====================================================================
# Endpoint del backend que conversa con el modelo (Claude). Si lo dejas
# vacío, el chat funciona en modo "guiado" con respuestas predefinidas.
# Ejemplo de función serverless lista para usar: ver functions/chat.example.ts
PUBLIC_AI_CHAT_ENDPOINT=""

# =====================================================================
#  REALIDAD AUMENTADA (model-viewer)
# =====================================================================
# Modelos 3D por defecto (GLB para 3D/AR Android, USDZ para AR iOS).
# Reemplázalos por modelos reales de tus muebles.
PUBLIC_AR_MODEL_GLB=""
PUBLIC_AR_MODEL_USDZ=""
