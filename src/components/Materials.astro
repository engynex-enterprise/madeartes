---
const finishes = [
  { name: "Roble natural", desc: "Cálido y versátil, el clásico atemporal.", sw: "linear-gradient(135deg,#e3c79b,#c79f6c)" },
  { name: "Nogal", desc: "Tono profundo y elegante para ambientes sobrios.", sw: "linear-gradient(135deg,#7a5235,#523524)" },
  { name: "Wengué", desc: "Casi negro, moderno y de alto contraste.", sw: "linear-gradient(135deg,#463a30,#251d17)" },
  { name: "Cerezo", desc: "Rojizo y acogedor, con mucho carácter.", sw: "linear-gradient(135deg,#a85c3c,#7c3f29)" },
  { name: "Blanco mate", desc: "Limpio y luminoso, ideal para espacios pequeños.", sw: "linear-gradient(135deg,#f4f0e9,#e1dace)" },
  { name: "Laca brillante", desc: "Acabado pulido que refleja la luz.", sw: "linear-gradient(135deg,#efe7da,#cdbfa8)" },
];
---

<section class="section section--dark section--glow" id="materiales">
  <span class="geo geo--ring" style="width:170px;height:170px;top:50px;right:-40px;"></span>
  <div class="container">
    <header class="section__head" data-reveal>
      <span class="eyebrow">Maderas y acabados</span>
      <h2>Elige el acabado que va con tu estilo</h2>
      <p>Trabajamos maderas nobles y una amplia gama de acabados. Te asesoramos para elegir el ideal.</p>
    </header>

    <div class="finishes">
      {
        finishes.map((f, i) => (
          <article class="finish" data-reveal style={`--d:${(i % 3) * 70}ms`}>
            <span class="finish__sw" style={`background:${f.sw}`}></span>
            <div class="finish__body">
              <h3>{f.name}</h3>
              <p>{f.desc}</p>
            </div>
          </article>
        ))
      }
    </div>
    <p class="finishes__note" data-reveal>¿Buscas un acabado específico? También trabajamos sobre pedido.</p>
  </div>
</section>
