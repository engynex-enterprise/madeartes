---
import Brand from "./Brand.astro";
import { site, whatsappLink } from "../config/site";
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <Brand light={true} />
      <p>Muebles de madera a medida para hogar y empresa. Diseño, fabricación e instalación con acabado artesanal.</p>
    </div>

    <div class="footer__col">
      <h4>Navegación</h4>
      <a href="/">Inicio</a>
      <a href="/servicios">Servicios</a>
      <a href="/proyectos">Proyectos</a>
      <a href="/nosotros">Nosotros</a>
      <a href="/contacto">Contacto</a>
    </div>

    <div class="footer__col">
      <h4>Legal</h4>
      <a href="/terminos">Términos y condiciones</a>
      <a href="/privacidad">Política de privacidad</a>
      <a href="/tratamiento-datos">Tratamiento de datos</a>
      <a href="/cookies">Política de cookies</a>
    </div>

    <div class="footer__col">
      <h4>Contacto</h4>
      <a href={whatsappLink()} target="_blank" rel="noopener">WhatsApp {site.whatsappPretty}</a>
      <a href="/contacto">Cotizar proyecto</a>
      <span>Lun a Sáb · 8:00 – 18:00</span>
      <span>Colombia</span>
    </div>
  </div>
  <div class="footer__bottom">
    <div class="container">
      <span>© {year} Madeartes. Todos los derechos reservados.</span>
      <span>Hecho con madera y dedicación 🪵</span>
    </div>
  </div>
</footer>
