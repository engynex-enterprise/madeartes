---
import { Icon } from "astro-icon/components";

const steps = [
  { icon: "lucide:messages-square", title: "Asesoría", text: "Hablamos de tu idea, espacio y presupuesto. Resolvemos dudas sin costo." },
  { icon: "lucide:pencil-ruler", title: "Diseño y cotización", text: "Tomamos medidas y te presentamos el diseño con una propuesta clara." },
  { icon: "lucide:hammer", title: "Fabricación", text: "Construimos tu mueble en el taller con maderas y acabados de calidad." },
  { icon: "lucide:truck", title: "Instalación", text: "Llevamos e instalamos todo, dejando tu espacio listo para disfrutar." },
];
---

<section class="section section--alt section--glow" id="proceso">
  <div class="container">
    <header class="section__head" data-reveal>
      <span class="eyebrow">Cómo trabajamos</span>
      <h2>De la idea al mueble en 4 pasos</h2>
      <p>Un proceso claro y acompañado, sin sorpresas en el camino.</p>
    </header>

    <ol class="timeline">
      {
        steps.map((s, i) => (
          <li class="timeline__step" data-reveal style={`--d:${i * 100}ms`}>
            <div class="timeline__node">
              <span class="timeline__num">{i + 1}</span>
            </div>
            <div class="timeline__card">
              <span class="timeline__icon"><Icon name={s.icon} width="24" height="24" /></span>
              <h3>{s.title}</h3>
              <p>{s.text}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
