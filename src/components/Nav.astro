---
import Brand from "./Brand.astro";

const links = [
  { href: "/", label: "Inicio" },
  { href: "/servicios", label: "Servicios" },
  { href: "/proyectos", label: "Proyectos" },
  { href: "/nosotros", label: "Nosotros" },
  { href: "/contacto", label: "Contacto" },
];

// Ruta actual (sin slash final) para marcar el enlace activo.
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
---

<header class="nav" id="top">
  <div class="container nav__inner">
    <Brand />

    <nav class="nav__links" aria-label="Menú principal">
      {links.map((l) => <a href={l.href} class={isActive(l.href) ? "active" : ""}>{l.label}</a>)}
    </nav>

    <a href="/contacto" class="btn btn--dark nav__cta">Cotiza tu proyecto</a>

    <button class="nav__toggle" id="navToggle" aria-label="Abrir menú" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav__mobile" id="navMobile">
    {links.map((l) => <a href={l.href} class={isActive(l.href) ? "active" : ""}>{l.label}</a>)}
    <a href="/contacto" class="btn btn--dark">Cotiza tu proyecto</a>
  </div>
</header>

<script>
  const toggle = document.getElementById("navToggle");
  const mobile = document.getElementById("navMobile");
  if (toggle && mobile) {
    toggle.addEventListener("click", () => {
      const open = mobile.classList.toggle("open");
      toggle.setAttribute("aria-expanded", String(open));
    });
    mobile.querySelectorAll("a").forEach((a) =>
      a.addEventListener("click", () => {
        mobile.classList.remove("open");
        toggle.setAttribute("aria-expanded", "false");
      })
    );
  }
</script>
