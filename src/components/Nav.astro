---
import { Icon } from "astro-icon/components";
import Brand from "./Brand.astro";
import Social from "./Social.astro";
import { site } from "../config/site";

const links = [
  { href: "/", label: "Inicio" },
  { href: "/servicios", label: "Servicios" },
  { href: "/proyectos", label: "Proyectos" },
  { href: "/nosotros", label: "Nosotros" },
  { href: "/contacto", label: "Contacto" },
];

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
---

<header class="nav" id="top">
  <!-- Barra superior: contacto + redes -->
  <div class="topbar">
    <div class="container topbar__inner">
      <div class="topbar__contact">
        <a href={`tel:+${site.whatsapp}`}><Icon name="lucide:phone" width="14" height="14" /> {site.whatsappPretty}</a>
        <a href={`mailto:${site.email}`}><Icon name="lucide:mail" width="14" height="14" /> {site.email}</a>
      </div>
      <div class="topbar__right">
        <span class="topbar__hours"><Icon name="lucide:clock" width="14" height="14" /> Lun–Sáb · 8:00–18:00</span>
        <Social cls="social--top" />
      </div>
    </div>
  </div>

  <!-- Barra principal -->
  <div class="container nav__inner">
    <Brand />

    <nav class="nav__links" aria-label="Menú principal">
      {links.map((l) => <a href={l.href} class={isActive(l.href) ? "active" : ""}>{l.label}</a>)}
    </nav>

    <a href="/contacto" class="btn btn--dark nav__cta">Cotiza tu proyecto</a>

    <button class="nav__toggle" id="navToggle" aria-label="Abrir menú" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav__mobile" id="navMobile">
    {links.map((l) => <a href={l.href} class={isActive(l.href) ? "active" : ""}>{l.label}</a>)}
    <a href="/contacto" class="btn btn--dark">Cotiza tu proyecto</a>
    <div class="nav__mobile-social">
      <Social />
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("navToggle");
  const mobile = document.getElementById("navMobile");
  if (toggle && mobile) {
    toggle.addEventListener("click", () => {
      const open = mobile.classList.toggle("open");
      toggle.setAttribute("aria-expanded", String(open));
    });
    mobile.querySelectorAll("a").forEach((a) =>
      a.addEventListener("click", () => {
        mobile.classList.remove("open");
        toggle.setAttribute("aria-expanded", "false");
      })
    );
  }
</script>
