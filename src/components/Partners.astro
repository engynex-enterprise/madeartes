---
import { Icon } from "astro-icon/components";

const items = [
  { icon: "lucide:home", label: "Hogares" },
  { icon: "lucide:building-2", label: "Oficinas" },
  { icon: "lucide:utensils", label: "Restaurantes" },
  { icon: "lucide:shopping-bag", label: "Comercios" },
  { icon: "lucide:bed-double", label: "Hoteles" },
  { icon: "lucide:hard-hat", label: "Constructoras" },
  { icon: "lucide:coffee", label: "Cafés" },
];
// Duplicamos para un marquee continuo.
const loop = [...items, ...items];
---

<section class="partners">
  <div class="container">
    <div class="trust">
      <span class="trust__rating">
        <span class="trust__stars">
          {[1, 2, 3, 4, 5].map(() => <Icon name="lucide:star" width="16" height="16" />)}
        </span>
        <strong>4.9/5</strong>
        <span class="trust__sep"></span>
        <span>+500 proyectos entregados en toda Colombia</span>
      </span>
    </div>
  </div>

  <div class="marquee" aria-hidden="true">
    <div class="marquee__track">
      {
        loop.map((i) => (
          <span class="marquee__item">
            <Icon name={i.icon} width="22" height="22" />
            {i.label}
            <span class="marquee__dot"></span>
          </span>
        ))
      }
    </div>
  </div>
</section>
