---
import { Icon } from "astro-icon/components";

const reviews = [
  { text: "Nos hicieron la cocina integral y quedó espectacular. Cumplieron tiempos y el acabado es de lujo.", name: "Laura Gómez", meta: "Hogar · Bogotá" },
  { text: "Amoblaron toda nuestra oficina. Profesionales, puntuales y el resultado proyecta justo la imagen que queríamos.", name: "Andrés Rincón", meta: "Empresa · Medellín" },
  { text: "El closet de mi habitación superó lo que imaginaba. Excelente atención de principio a fin.", name: "Carolina Ruiz", meta: "Hogar · Cali" },
];
---

<section class="section section--alt" id="opiniones">
  <div class="container">
    <header class="section__head" data-reveal>
      <span class="eyebrow">Opiniones</span>
      <h2>Lo que dicen nuestros clientes</h2>
      <p>La confianza de quienes ya transformaron sus espacios con nosotros.</p>
    </header>

    <div class="reviews">
      {
        reviews.map((r, i) => (
          <blockquote class="review" data-reveal style={`--d:${i * 80}ms`}>
            <p class="review__stars">
              {[1, 2, 3, 4, 5].map(() => (
                <Icon name="lucide:star" width="18" height="18" />
              ))}
            </p>
            <p>“{r.text}”</p>
            <footer>
              <strong>{r.name}</strong>
              <span>{r.meta}</span>
            </footer>
          </blockquote>
        ))
      }
    </div>
  </div>
</section>
