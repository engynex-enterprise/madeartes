---
import { Icon } from "astro-icon/components";

const featured = {
  text: "Nos hicieron la cocina integral y quedó espectacular. Cumplieron los tiempos, el acabado es de lujo y la atención fue impecable de principio a fin. Sin duda los volveríamos a contratar.",
  name: "Laura Gómez",
  meta: "Cocina integral · Bogotá",
  initials: "LG",
};

const reviews = [
  { text: "Amoblaron toda nuestra oficina. Profesionales, puntuales y el resultado proyecta justo la imagen que queríamos.", name: "Andrés Rincón", meta: "Empresa · Medellín", initials: "AR" },
  { text: "El closet de mi habitación superó lo que imaginaba. Excelente atención y acabados de primera.", name: "Carolina Ruiz", meta: "Closet · Cali", initials: "CR" },
  { text: "Compramos el comedor en madera maciza y es una pieza preciosa. Calidad que se nota y se siente.", name: "Felipe Torres", meta: "Comedor · Bogotá", initials: "FT" },
];

const stats = [
  { num: "+500", label: "proyectos entregados" },
  { num: "15+", label: "años de experiencia" },
  { num: "4.9★", label: "calificación promedio" },
];
---

<section class="section section--glow" id="opiniones">
  <div class="container">
    <header class="section__head" data-reveal>
      <span class="eyebrow">Opiniones</span>
      <h2>Lo que dicen nuestros clientes</h2>
      <p>La confianza de quienes ya transformaron sus espacios con nosotros.</p>
    </header>

    <div class="testimonials">
      <blockquote class="testimonial-feature" data-reveal>
        <Icon class="testimonial-feature__quote" name="lucide:quote" width="46" height="46" />
        <p class="review__stars">
          {[1, 2, 3, 4, 5].map(() => <Icon name="lucide:star" width="18" height="18" />)}
        </p>
        <p class="testimonial-feature__text">{featured.text}</p>
        <footer>
          <span class="avatar">{featured.initials}</span>
          <span>
            <strong>{featured.name}</strong>
            <span class="testimonial__meta">{featured.meta}</span>
          </span>
        </footer>
      </blockquote>

      <div class="testimonial-list">
        {
          reviews.map((r, i) => (
            <blockquote class="testimonial-card" data-reveal style={`--d:${i * 80}ms`}>
              <p class="review__stars">
                {[1, 2, 3, 4, 5].map(() => <Icon name="lucide:star" width="15" height="15" />)}
              </p>
              <p>“{r.text}”</p>
              <footer>
                <span class="avatar avatar--sm">{r.initials}</span>
                <span>
                  <strong>{r.name}</strong>
                  <span class="testimonial__meta">{r.meta}</span>
                </span>
              </footer>
            </blockquote>
          ))
        }
      </div>
    </div>

    <div class="stats" data-reveal>
      {
        stats.map((s) => (
          <div class="stat">
            <strong>{s.num}</strong>
            <span>{s.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>
