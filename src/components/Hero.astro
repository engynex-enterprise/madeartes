---
import { Icon } from "astro-icon/components";
import { site, google, whatsappLink } from "../config/site";

const slides = [
  {
    tag: "Línea Hogar",
    title: "Muebles que dan vida a tu hogar",
    text: "Cocinas, closets y comedores a medida con acabado artesanal, pensados para tu día a día.",
    img: "https://images.unsplash.com/photo-1616486338812-3dadae4b4ace?auto=format&fit=crop&w=1600&q=80",
  },
  {
    tag: "Línea Empresa",
    title: "Espacios que proyectan tu marca",
    text: "Mobiliario corporativo para oficinas, restaurantes, hoteles y comercios. Diseño que comunica.",
    img: "https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1600&q=80",
  },
  {
    tag: "Cocinas integrales",
    title: "Tu cocina, hecha a tu medida",
    text: "Optimizamos cada centímetro con diseño funcional, herrajes de calidad y acabados que perduran.",
    img: "https://images.unsplash.com/photo-1556909212-d5b604d0c90d?auto=format&fit=crop&w=1600&q=80",
  },
  {
    tag: "Closets y vestidores",
    title: "Orden y elegancia en cada rincón",
    text: "Almacenamiento inteligente con diseño a la medida de tu espacio y tu estilo de vida.",
    img: "https://images.unsplash.com/photo-1595428774223-ef52624120d2?auto=format&fit=crop&w=1600&q=80",
  },
];

const clientConfig = {
  whatsapp: site.whatsapp,
  adsId: google.adsId,
  adsConversionLabel: google.adsConversionLabel,
};
---

<section class="hero">
  <div class="hero-slider" id="inicio" data-hero-slider aria-label="Destacados">
    <div class="hero-slider__track">
      {
        slides.map((s, i) => (
          <article
            class={`slide${i === 0 ? " is-active" : ""}`}
            data-slide
            style={`background-image:url('${s.img}')`}
            aria-hidden={i === 0 ? "false" : "true"}
          >
            <span class="slide__overlay" />
            <div class="container slide__inner">
              <span class="badge badge--light">
                <Icon name="lucide:sparkles" width="15" height="15" />
                {s.tag}
              </span>
              <h1 class="slide__title">{s.title}</h1>
              <p class="slide__text">{s.text}</p>
              <div class="slide__actions">
                <a href="/servicios" class="btn btn--glass">Ver servicios →</a>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <div class="container hero-slider__controls">
      <button class="hs-arrow" data-prev aria-label="Anterior">
        <Icon name="lucide:chevron-left" width="22" height="22" />
      </button>
      <div class="hero-slider__dots" data-dots>
        {slides.map((s, i) => <button class={`dot${i === 0 ? " is-active" : ""}`} data-dot aria-label={`Ir a ${s.tag}`} />)}
      </div>
      <button class="hs-arrow" data-next aria-label="Siguiente">
        <Icon name="lucide:chevron-right" width="22" height="22" />
      </button>
    </div>
  </div>

  <!-- Formulario de cotización rápida a la derecha -->
  <div class="hero-form-wrap">
    <div class="container hero-form-grid">
      <div></div>
      <form class="hero-form" id="heroForm" novalidate>
        <h2 class="hero-form__title">Cotiza tu proyecto <span>gratis</span></h2>
        <p class="hero-form__sub">Déjanos tus datos y te contactamos por WhatsApp.</p>

        <div class="segmented" role="radiogroup" aria-label="Línea">
          <label class="segmented__opt">
            <input type="radio" name="hlinea" value="Línea Hogar" checked />
            <span><Icon name="lucide:home" width="17" height="17" /> Hogar</span>
          </label>
          <label class="segmented__opt">
            <input type="radio" name="hlinea" value="Línea Empresa" />
            <span><Icon name="lucide:building-2" width="17" height="17" /> Empresa</span>
          </label>
        </div>

        <div class="field">
          <div class="input-wrap">
            <Icon class="input-wrap__ico" name="lucide:user" width="18" height="18" />
            <input type="text" id="hnombre" name="hnombre" placeholder="Tu nombre" required />
          </div>
        </div>
        <div class="field">
          <div class="input-wrap">
            <Icon class="input-wrap__ico" name="lucide:phone" width="18" height="18" />
            <input type="tel" id="htelefono" name="htelefono" placeholder="Teléfono" required />
          </div>
        </div>
        <div class="field">
          <div class="input-wrap">
            <Icon class="input-wrap__ico" name="lucide:pencil" width="18" height="18" />
            <input type="text" id="hmensaje" name="hmensaje" placeholder="¿Qué necesitas? (ej. cocina)" />
          </div>
        </div>

        <button type="submit" class="btn btn--primary btn--block">
          <Icon name="lucide:send" width="18" height="18" /> Solicitar cotización
        </button>
        <p class="hero-form__note">
          O escríbenos directo al <a href={whatsappLink()} target="_blank" rel="noopener">{site.whatsappPretty}</a>
        </p>
      </form>
    </div>
  </div>
</section>

<script>
  const root = document.querySelector<HTMLElement>("[data-hero-slider]");
  if (root) {
    const slides = Array.from(root.querySelectorAll<HTMLElement>("[data-slide]"));
    const dots = Array.from(root.querySelectorAll<HTMLElement>("[data-dot]"));
    const prev = root.querySelector<HTMLButtonElement>("[data-prev]");
    const next = root.querySelector<HTMLButtonElement>("[data-next]");
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let idx = 0;
    let timer: number | undefined;

    const go = (n: number) => {
      slides[idx].classList.remove("is-active");
      slides[idx].setAttribute("aria-hidden", "true");
      dots[idx]?.classList.remove("is-active");
      idx = (n + slides.length) % slides.length;
      slides[idx].classList.add("is-active");
      slides[idx].setAttribute("aria-hidden", "false");
      dots[idx]?.classList.add("is-active");
    };

    const start = () => {
      if (reduce) return;
      stop();
      timer = window.setInterval(() => go(idx + 1), 6000);
    };
    const stop = () => timer && window.clearInterval(timer);

    next?.addEventListener("click", () => { go(idx + 1); start(); });
    prev?.addEventListener("click", () => { go(idx - 1); start(); });
    dots.forEach((d, i) => d.addEventListener("click", () => { go(i); start(); }));

    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);
    start();
  }
</script>

<script is:inline define:vars={{ cfg: clientConfig }}>
  (function () {
    const form = document.getElementById("heroForm");
    if (!form) return;
    form.addEventListener("submit", function (e) {
      e.preventDefault();
      const nombre = form.hnombre, telefono = form.htelefono, mensaje = form.hmensaje;
      const linea = form.querySelector('input[name="hlinea"]:checked');
      let ok = true;
      [nombre, telefono].forEach(function (f) {
        const wrap = f.closest(".input-wrap") || f;
        if (!f.value.trim()) { f.classList.add("invalid"); wrap.classList.add("invalid"); ok = false; }
        else { f.classList.remove("invalid"); wrap.classList.remove("invalid"); }
      });
      if (!ok) { nombre.value.trim() ? telefono.focus() : nombre.focus(); return; }

      if (window.gtag && cfg.adsId && cfg.adsConversionLabel) {
        window.gtag("event", "conversion", { send_to: cfg.adsId + "/" + cfg.adsConversionLabel });
      }
      if (window.dataLayer) window.dataLayer.push({ event: "generate_lead", form: "hero_whatsapp" });

      const texto =
        "Hola Madeartes 👋, quiero cotizar un proyecto.\n\n" +
        "*Línea:* " + (linea ? linea.value : "Hogar") + "\n" +
        "*Nombre:* " + nombre.value.trim() + "\n" +
        "*Teléfono:* " + telefono.value.trim() +
        (mensaje.value.trim() ? "\n*Necesita:* " + mensaje.value.trim() : "");
      window.open("https://wa.me/" + cfg.whatsapp + "?text=" + encodeURIComponent(texto), "_blank");
    });
    form.querySelectorAll("input").forEach(function (el) {
      el.addEventListener("input", function () {
        el.classList.remove("invalid");
        const wrap = el.closest(".input-wrap");
        if (wrap) wrap.classList.remove("invalid");
      });
    });
  })();
</script>
