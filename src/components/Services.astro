---
import { Icon } from "astro-icon/components";

// El primer servicio es destacado (ocupa una celda grande del bento).
const featured = {
  title: "Cocinas integrales",
  text: "El corazón del hogar, optimizado al milímetro. Diseño funcional, herrajes de calidad y acabados que perduran.",
  img: "https://images.unsplash.com/photo-1556911220-bff31c812dba?auto=format&fit=crop&w=1000&q=80",
  alt: "Cocina integral de madera",
  icon: "lucide:chef-hat",
};

const services = [
  { title: "Closets y vestidores", text: "Almacenamiento inteligente con acabados finos.", img: "https://images.unsplash.com/photo-1558997519-83ea9252edf8?auto=format&fit=crop&w=700&q=80", alt: "Closet de madera a medida", icon: "lucide:shirt" },
  { title: "Comedores y mesas", text: "Madera maciza para reunir a los tuyos.", img: "https://images.unsplash.com/photo-1617806118233-18e1de247200?auto=format&fit=crop&w=700&q=80", alt: "Comedor de madera", icon: "lucide:utensils" },
  { title: "Mobiliario corporativo", text: "Escritorios y recepciones que proyectan tu marca.", img: "https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&fit=crop&w=700&q=80", alt: "Mobiliario corporativo de madera", icon: "lucide:briefcase" },
  { title: "Salas y muebles de estar", text: "Piezas cómodas con carácter para tu sala.", img: "https://images.unsplash.com/photo-1524758631624-e2822e304c36?auto=format&fit=crop&w=700&q=80", alt: "Muebles de sala de madera", icon: "lucide:sofa" },
];
---

<section class="section" id="servicios">
  <div class="container">
    <header class="section__head" data-reveal>
      <span class="eyebrow">Nuestros servicios</span>
      <h2>Lo que fabricamos para ti</h2>
      <p>Mobiliario en madera diseñado para durar, pensado para cada ambiente del hogar y del negocio.</p>
    </header>

    <div class="bento">
      <article class="bento__feature" data-reveal style={`background-image:url('${featured.img}')`}>
        <div class="bento__overlay"></div>
        <div class="bento__content">
          <span class="bento__icon"><Icon name={featured.icon} width="24" height="24" /></span>
          <h3>{featured.title}</h3>
          <p>{featured.text}</p>
          <a href="#contacto" class="bento__link">Cotizar <Icon name="lucide:arrow-right" width="16" height="16" /></a>
        </div>
      </article>

      {
        services.map((s, i) => (
          <article class="bento__card" data-reveal style={`--d:${i * 70}ms`}>
            <div class="bento__media"><img src={s.img} alt={s.alt} loading="lazy" width="700" height="500" /></div>
            <div class="bento__card-body">
              <span class="bento__chip"><Icon name={s.icon} width="18" height="18" /></span>
              <div>
                <h3>{s.title}</h3>
                <p>{s.text}</p>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
