---
import { Icon } from "astro-icon/components";
import Social from "./Social.astro";
import { site, google, whatsappLink } from "../config/site";

const tipos = [
  "Cocina integral",
  "Closet o vestidor",
  "Comedor o mesa",
  "Sala / muebles de estar",
  "Mobiliario corporativo",
  "Recepción / mostrador",
  "Otro",
];

const methods = [
  { icon: "lucide:message-circle", title: "WhatsApp", value: site.whatsappPretty, href: whatsappLink("Hola Madeartes, quiero cotizar un proyecto."), accent: "wa" },
  { icon: "lucide:phone", title: "Llámanos", value: site.whatsappPretty, href: `tel:+${site.whatsapp}`, accent: "" },
  { icon: "lucide:mail", title: "Correo", value: site.email, href: `mailto:${site.email}`, accent: "" },
  { icon: "lucide:map-pin", title: "Cobertura", value: "Toda Colombia", href: "#mapa", accent: "" },
];

const clientConfig = { whatsapp: site.whatsapp, adsId: google.adsId, adsConversionLabel: google.adsConversionLabel };
---

<section class="section section--glow" id="contacto">
  <span class="geo geo--blob" style="width:240px;height:240px;top:-60px;left:-60px;"></span>
  <span class="geo geo--dots" style="bottom:40px;right:30px;"></span>

  <div class="container">
    <!-- tarjetas de contacto rápido -->
    <div class="methods" data-reveal>
      {
        methods.map((m) => (
          <a class={`method${m.accent === "wa" ? " method--wa" : ""}`} href={m.href} target={m.href.startsWith("http") ? "_blank" : undefined} rel="noopener">
            <span class="method__icon"><Icon name={m.icon} width="22" height="22" /></span>
            <span class="method__body">
              <strong>{m.title}</strong>
              <span>{m.value}</span>
            </span>
            <Icon class="method__arrow" name="lucide:arrow-up-right" width="18" height="18" />
          </a>
        ))
      }
    </div>

    <!-- split: panel oscuro + formulario -->
    <div class="contact-grid">
      <aside class="contact-aside" data-reveal>
        <svg class="contact-aside__rings" viewBox="0 0 320 320" aria-hidden="true">
          <g fill="none" stroke="currentColor" stroke-width="2">
            <ellipse cx="160" cy="160" rx="22" ry="24" />
            <ellipse cx="156" cy="162" rx="48" ry="52" />
            <ellipse cx="162" cy="158" rx="78" ry="82" />
            <ellipse cx="158" cy="161" rx="110" ry="114" />
            <ellipse cx="161" cy="159" rx="142" ry="146" />
          </g>
        </svg>
        <div class="contact-aside__top">
          <span class="eyebrow">Estamos para ayudarte</span>
          <h2>Diseñemos juntos tu próximo mueble</h2>
          <p>Cuéntanos qué tienes en mente. Te asesoramos sin costo y, al enviar el formulario, abrimos WhatsApp con tu mensaje listo para conversar al instante.</p>
        </div>
        <ul class="contact-aside__list">
          <li><span class="contact-aside__ico"><Icon name="lucide:zap" width="18" height="18" /></span> Respuesta el mismo día hábil</li>
          <li><span class="contact-aside__ico"><Icon name="lucide:badge-check" width="18" height="18" /></span> Cotización sin compromiso</li>
          <li><span class="contact-aside__ico"><Icon name="lucide:ruler" width="18" height="18" /></span> Diseño a la medida de tu espacio</li>
        </ul>
        <div class="contact-aside__social">
          <span>Síguenos</span>
          <Social cls="social--footer" />
        </div>
      </aside>

      <form class="contact__form contact-form" id="contactForm" novalidate data-reveal>
        <div class="field">
          <label>¿Es para hogar o empresa? *</label>
          <div class="segmented" role="radiogroup" aria-label="Línea de producto">
            <label class="segmented__opt">
              <input type="radio" name="linea" value="Línea Hogar" checked />
              <span><Icon name="lucide:home" width="18" height="18" /> Hogar</span>
            </label>
            <label class="segmented__opt">
              <input type="radio" name="linea" value="Línea Empresa" />
              <span><Icon name="lucide:building-2" width="18" height="18" /> Empresa</span>
            </label>
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label for="nombre">Nombre completo *</label>
            <div class="input-wrap">
              <Icon class="input-wrap__ico" name="lucide:user" width="18" height="18" />
              <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" required />
            </div>
          </div>
          <div class="field">
            <label for="telefono">Teléfono *</label>
            <div class="input-wrap">
              <Icon class="input-wrap__ico" name="lucide:phone" width="18" height="18" />
              <input type="tel" id="telefono" name="telefono" placeholder="300 123 4567" required />
            </div>
          </div>
        </div>

        <div class="field">
          <label id="tipoLabel">Tipo de proyecto</label>
          <div class="cs" data-select>
            <button type="button" class="cs__trigger" aria-haspopup="listbox" aria-expanded="false" aria-labelledby="tipoLabel">
              <span class="cs__value" data-value>{tipos[0]}</span>
              <Icon class="cs__chevron" name="lucide:chevron-down" width="18" height="18" />
            </button>
            <input type="hidden" name="tipo" id="tipo" value={tipos[0]} />
            <ul class="cs__panel" role="listbox" tabindex="-1" aria-labelledby="tipoLabel">
              {tipos.map((t, i) => (
                <li class="cs__option" role="option" data-val={t} tabindex="-1" aria-selected={i === 0 ? "true" : "false"}>
                  <span>{t}</span>
                  <Icon class="cs__check" name="lucide:check" width="17" height="17" />
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="field">
          <label for="mensaje">Cuéntanos los detalles *</label>
          <textarea id="mensaje" name="mensaje" rows="4" placeholder="Describe tu proyecto, medidas aproximadas, estilo..." required></textarea>
        </div>

        <button type="submit" class="btn btn--primary btn--block">
          <Icon name="lucide:send" width="18" height="18" /> Enviar por WhatsApp
        </button>

        <p class="form-success" id="formSuccess" hidden>
          <Icon name="lucide:circle-check-big" width="18" height="18" />
          ¡Listo! Abrimos WhatsApp con tu mensaje. Si no se abrió, <a href={whatsappLink()} target="_blank" rel="noopener">escríbenos aquí</a>.
        </p>
        <p class="contact__note">Tus datos solo se usan para contactarte. No compartimos tu información.</p>
      </form>
    </div>
  </div>
</section>

<script is:inline define:vars={{ cfg: clientConfig }}>
  (function () {
    const form = document.getElementById("contactForm");
    if (!form) return;
    const success = document.getElementById("formSuccess");

    form.addEventListener("submit", function (e) {
      e.preventDefault();
      const nombre = form.nombre, telefono = form.telefono, tipo = form.tipo, mensaje = form.mensaje;
      const linea = form.querySelector('input[name="linea"]:checked');
      let ok = true;
      [nombre, telefono, mensaje].forEach(function (field) {
        const wrap = field.closest(".input-wrap") || field;
        if (!field.value.trim()) { field.classList.add("invalid"); wrap.classList.add("invalid"); ok = false; }
        else { field.classList.remove("invalid"); wrap.classList.remove("invalid"); }
      });
      if (!ok) { (nombre.value.trim() ? telefono : nombre).focus(); return; }

      if (window.gtag && cfg.adsId && cfg.adsConversionLabel) {
        window.gtag("event", "conversion", { send_to: cfg.adsId + "/" + cfg.adsConversionLabel });
      }
      if (window.dataLayer) window.dataLayer.push({ event: "generate_lead", form: "contacto_whatsapp" });

      const texto =
        "Hola Madeartes 👋, quiero cotizar un proyecto.\n\n" +
        "*Línea:* " + (linea ? linea.value : "Hogar") + "\n" +
        "*Nombre:* " + nombre.value.trim() + "\n" +
        "*Teléfono:* " + telefono.value.trim() + "\n" +
        "*Tipo:* " + tipo.value + "\n" +
        "*Detalles:* " + mensaje.value.trim();
      window.open("https://wa.me/" + cfg.whatsapp + "?text=" + encodeURIComponent(texto), "_blank");
      if (success) { success.hidden = false; success.scrollIntoView({ behavior: "smooth", block: "nearest" }); }
    });

    form.querySelectorAll("input, textarea").forEach(function (el) {
      el.addEventListener("input", function () {
        el.classList.remove("invalid");
        const wrap = el.closest(".input-wrap");
        if (wrap) wrap.classList.remove("invalid");
        if (success) success.hidden = true;
      });
    });
  })();
</script>

<script>
  // Dropdown personalizado (estilo shadcn)
  document.querySelectorAll<HTMLElement>("[data-select]").forEach((root) => {
    const trigger = root.querySelector<HTMLButtonElement>(".cs__trigger");
    const valueEl = root.querySelector<HTMLElement>("[data-value]");
    const hidden = root.querySelector<HTMLInputElement>('input[type="hidden"]');
    const options = Array.from(root.querySelectorAll<HTMLElement>(".cs__option"));
    if (!trigger || !valueEl || !hidden) return;
    let open = false;
    let focusIdx = Math.max(0, options.findIndex((o) => o.getAttribute("aria-selected") === "true"));
    const setOpen = (o: boolean) => {
      open = o;
      root.classList.toggle("open", o);
      trigger.setAttribute("aria-expanded", String(o));
      if (o) { focusIdx = Math.max(0, options.findIndex((x) => x.getAttribute("aria-selected") === "true")); highlight(); }
    };
    const highlight = () => { options.forEach((o, i) => o.classList.toggle("focus", i === focusIdx)); options[focusIdx]?.scrollIntoView({ block: "nearest" }); };
    const choose = (opt: HTMLElement) => {
      options.forEach((o) => o.setAttribute("aria-selected", "false"));
      opt.setAttribute("aria-selected", "true");
      const val = opt.dataset.val || "";
      valueEl.textContent = val; hidden.value = val; setOpen(false); trigger.focus();
    };
    trigger.addEventListener("click", () => setOpen(!open));
    options.forEach((opt, i) => {
      opt.addEventListener("click", () => choose(opt));
      opt.addEventListener("mousemove", () => { focusIdx = i; highlight(); });
    });
    trigger.addEventListener("keydown", (e) => {
      if (["ArrowDown", "ArrowUp", "Enter", " "].includes(e.key)) { e.preventDefault(); if (!open) { setOpen(true); return; } }
      if (!open) return;
      if (e.key === "ArrowDown") { focusIdx = (focusIdx + 1) % options.length; highlight(); }
      else if (e.key === "ArrowUp") { focusIdx = (focusIdx - 1 + options.length) % options.length; highlight(); }
      else if (e.key === "Enter" || e.key === " ") { choose(options[focusIdx]); }
      else if (e.key === "Escape") { setOpen(false); }
    });
    document.addEventListener("click", (e) => { if (!root.contains(e.target as Node)) setOpen(false); });
  });
</script>
