---
const projects = [
  { img: "https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=700&q=80", alt: "Proyecto de muebles de madera para dormitorio" },
  { img: "https://images.unsplash.com/photo-1524758631624-e2822e304c36?auto=format&fit=crop&w=700&q=80", alt: "Sala con muebles de madera" },
  { img: "https://images.unsplash.com/photo-1567016432779-094069958ea5?auto=format&fit=crop&w=700&q=80", alt: "Mueble de madera para oficina" },
  { img: "https://images.unsplash.com/photo-1493663284031-b7e3aefcae8e?auto=format&fit=crop&w=700&q=80", alt: "Detalle de carpintería en madera" },
];
---

<section class="section section--alt" id="proyectos">
  <div class="container">
    <header class="section__head" data-reveal>
      <span class="eyebrow">Proyectos</span>
      <h2>Trabajo que habla por sí solo</h2>
      <p>Una selección de piezas fabricadas e instaladas por nuestro equipo.</p>
    </header>

    <div class="gallery">
      {
        projects.map((p, i) => (
          <figure data-reveal style={`--d:${i * 70}ms`}>
            <img src={p.img} alt={p.alt} loading="lazy" width="700" height="933" />
          </figure>
        ))
      }
    </div>
  </div>
</section>
