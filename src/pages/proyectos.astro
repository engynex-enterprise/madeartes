---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import FeaturedProject from "../components/FeaturedProject.astro";
import Projects from "../components/Projects.astro";
import BeforeAfter from "../components/BeforeAfter.astro";
import Reviews from "../components/Reviews.astro";
import Cta from "../components/Cta.astro";
---

<Layout
  title="Proyectos | Madeartes — Trabajos en madera"
  description="Una selección de cocinas, closets, comedores y mobiliario corporativo que diseñamos, fabricamos e instalamos en hogares y empresas de Colombia."
>
  <PageHeader
    eyebrow="Proyectos"
    title="Trabajo que habla por sí solo"
    text="Explora algunas de las piezas que hemos fabricado e instalado para hogares y empresas en todo el país."
    current="Proyectos"
    image="https://images.unsplash.com/photo-1524758631624-e2822e304c36?auto=format&fit=crop&w=1600&q=80"
  />
  <FeaturedProject />
  <Projects />
  <BeforeAfter />
  <Reviews />
  <Cta />
</Layout>
