---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import AboutStory from "../components/AboutStory.astro";
import Milestones from "../components/Milestones.astro";
import WhyUs from "../components/WhyUs.astro";
import Process from "../components/Process.astro";
import Team from "../components/Team.astro";
import Cta from "../components/Cta.astro";
---

<Layout
  title="Nosotros | Madeartes — Carpintería fina"
  description="Más de 15 años de oficio en carpintería. Conoce nuestra historia, nuestro equipo y por qué cientos de hogares y empresas confían en Madeartes."
>
  <PageHeader
    eyebrow="Sobre Madeartes"
    title="Madera, oficio y dedicación"
    text="Somos un taller con más de 15 años creando muebles de madera a medida. Cada pieza nace de un proceso claro, materiales nobles y un equipo que ama lo que hace."
    current="Nosotros"
    image="https://images.unsplash.com/photo-1503602642458-232111445657?auto=format&fit=crop&w=1600&q=80"
  />
  <AboutStory />
  <Milestones />
  <WhyUs />
  <Process />
  <Team />
  <Cta />
</Layout>
